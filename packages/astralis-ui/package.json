{
  "name": "astralis-ui",
  "version": "0.2.0",
  "description": "React 19 component library on semantic design tokens — precompiled CSS, runtime brand theming, responsive style props, 62 components.",
  "type": "module",
  "types": "dist/index.d.ts",
  "author": "Paul Andrew",
  "license": "MIT",
  "homepage": "https://astralis-zeta.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SekiroDev360/astralis-ui.git",
    "directory": "packages/astralis-ui"
  },
  "bugs": {
    "url": "https://github.com/SekiroDev360/astralis-ui/issues"
  },
  "keywords": [
    "react",
    "react19",
    "components",
    "component-library",
    "ui",
    "design-system",
    "design-tokens",
    "theming",
    "dark-mode",
    "tailwind"
  ],
  "packageManager": "pnpm@10.15.1",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme-math": {
      "types": "./theme-math.d.ts",
      "import": "./dist/theme/theme-math.js"
    },
    "./color-math": {
      "types": "./theme-math.d.ts",
      "import": "./dist/theme/theme-math.js"
    },
    "./serialize": {
      "types": "./serialize.d.ts",
      "import": "./dist/theme/serialize.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "theme-math.d.ts",
    "serialize.d.ts"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "pnpm storybook",
    "dev:library": "concurrently \"pnpm run dev:types\" \"pnpm run dev:lib\" \"pnpm run dev:css\"",
    "dev:types": "tsc -p tsconfig.build.json --watch",
    "dev:lib": "vite build --watch",
    "gen:safelist": "node scripts/gen-responsive-safelist.mjs",
    "gen:semantic": "node scripts/gen-semantic-css.mjs",
    "check:tokens": "node scripts/check-token-sync.mjs",
    "dev:css": "pnpm run gen:safelist && tailwindcss -w -i ./src/tailwind-entry.css -o ./dist/styles.css",
    "build": "vite build && node scripts/check-server-safe.mjs && pnpm run build:css",
    "build:types": "tsc -p tsconfig.build.json",
    "build:css": "pnpm run check:tokens && pnpm run gen:safelist && tailwindcss -m -i ./src/tailwind-entry.css -o ./dist/styles.css && node scripts/check-css-coverage.mjs",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "concurrently \"pnpm run storybook:css\" \"storybook dev -p 6006\"",
    "storybook:css": "pnpm run gen:safelist && tailwindcss -w -i ./src/tailwind-entry.css -o ./src/index.css",
    "build-storybook": "concurrently \"pnpm run build-storybook:css\" \"storybook build\"",
    "build-storybook:css": "pnpm run gen:safelist && tailwindcss -m -i ./src/tailwind-entry.css -o ./src/index.css",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/js": "^9.33.0",
    "@storybook/addon-a11y": "^9.1.5",
    "@storybook/addon-docs": "^9.1.5",
    "@storybook/addon-themes": "^9.1.5",
    "@storybook/addon-vitest": "^9.1.5",
    "@storybook/react-vite": "^9.1.5",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^9.1.5",
    "esbuild": "^0.25.12",
    "globals": "^16.3.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.554.0",
    "playwright": "^1.55.0",
    "postcss": "^8.5.6",
    "storybook": "^9.1.5",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "qrcode": "^1.5.4",
    "tailwind-merge": "^3.6.0"
  }
}
